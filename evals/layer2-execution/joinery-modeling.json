  {
    "id": "joinery-004",
    "category": "joinery-modeling",
    "description": "Boolean subtract a mortise pocket (1/4 x 1 x 3 inches) into a table leg",
    "setup": [
      {
        "tool": "create_component_box",
        "params": {
          "name": "Table Leg",
          "position": [0, 0, 0],
          "dimensions": [1.5, 1.5, 29],
          "material": "White Oak",
          "tag": "Frame"
        }
      }
    ],
    "operation": {
      "tool": "boolean_subtract",
      "params": {
        "target": "Table Leg",
        "cutter_type": "box",
        "position": [0.625, -0.01, 25],
        "dimensions": [0.25, 1.0, 3.0]
      }
    },
    "verify": [
      {
        "tool": "verify_bounds",
        "params": {
          "expected": "{\"Table Leg\": {\"x\": [0, 1.5], \"y\": [0, 1.5], \"z\": [0, 29]}}"
        },
        "note": "Bounding box unchanged — mortise is an interior pocket"
      },
      {
        "tool": "eval_ruby",
        "params": {
          "code": "WW.check_solids.all? { |r| r[:solid] }"
        },
        "expected": true
      }
    ]
  },
  {
    "id": "joinery-005",
    "category": "joinery-modeling",
    "description": "Create a mortise-and-tenon joint pairing an apron to a table leg",
    "setup": [
      {
        "tool": "create_component_box",
        "params": {
          "name": "Front Leg",
          "position": [0, 0, 0],
          "dimensions": [1.5, 1.5, 29],
          "material": "White Oak",
          "tag": "Frame"
        }
      },
      {
        "tool": "create_component_box",
        "params": {
          "name": "Side Apron",
          "position": [1.5, 0.25, 25],
          "dimensions": [20, 1.0, 3.5],
          "material": "White Oak",
          "tag": "Frame"
        }
      }
    ],
    "operation": {
      "tool": "create_mortise_tenon",
      "params": {
        "mortise_id": "Front Leg",
        "tenon_id": "Side Apron",
        "width": 0.25,
        "height": 3.0,
        "depth": 1.0,
        "offset_x": 0,
        "offset_y": 0,
        "offset_z": 0
      }
    },
    "verify": [
      {
        "tool": "eval_ruby",
        "params": {
          "code": "WW.check_solids.all? { |r| r[:solid] }"
        },
        "expected": true
      },
      {
        "tool": "eval_ruby",
        "params": {
          "code": "Sketchup.active_model.entities.grep(Sketchup::Group).count + Sketchup.active_model.entities.grep(Sketchup::ComponentInstance).count"
        },
        "expected": 2,
        "note": "Still exactly 2 components after joint creation"
      }
    ]
  },

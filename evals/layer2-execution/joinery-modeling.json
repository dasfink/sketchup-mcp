[
  {
    "id": "joinery-001",
    "category": "joinery-modeling",
    "description": "Cut a standard 3/4-inch dado into 3/4-inch stock (shelf dado in a bookcase side)",
    "setup": [
      {
        "tool": "create_component_box",
        "params": {
          "name": "Side Panel",
          "position": [0, 0, 0],
          "dimensions": [0.75, 11.25, 30],
          "material": "Pine",
          "tag": "Carcase"
        }
      }
    ],
    "operation": {
      "tool": "safe_cut_dado",
      "params": {
        "component_name": "Side Panel",
        "face": "y+",
        "z_start": 12,
        "z_end": 12.75,
        "depth": 0.375
      }
    },
    "verify": [
      {
        "tool": "verify_bounds",
        "params": {
          "expected": "{\"Side Panel\": {\"x\": [0, 0.75], \"y\": [0, 11.25], \"z\": [0, 30]}}"
        },
        "note": "Overall bounding box unchanged — dado is an interior cut"
      },
      {
        "tool": "eval_ruby",
        "params": {
          "code": "WW.check_solids.all? { |r| r[:solid] }"
        },
        "expected": true
      }
    ]
  },

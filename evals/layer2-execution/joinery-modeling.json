  {
    "id": "joinery-010",
    "category": "joinery-modeling",
    "description": "WW.dado via eval_ruby — cut a 3/4-inch dado into a shelf side using the WW helper library",
    "setup": [
      {
        "tool": "eval_ruby",
        "params": {
          "code": "WW.reset!; WW.board('WW Side Panel', '1x12', 30, material: 'Pine')"
        }
      }
    ],
    "operation": {
      "tool": "eval_ruby",
      "params": {
        "code": "WW.dado('WW Side Panel', face: :top, at: 12, width: 0.75, depth: 0.375)"
      }
    },
    "verify": [
      {
        "tool": "eval_ruby",
        "params": {
          "code": "WW.check_solids.all? { |r| r[:solid] }"
        },
        "expected": true
      },
      {
        "tool": "eval_ruby",
        "params": {
          "code": "b = WW.list_boards.find { |r| r[:name] == 'WW Side Panel' }; b && b[:valid]"
        },
        "expected": true,
        "note": "Board is still tracked and valid after dado cut"
      }
    ]
  },

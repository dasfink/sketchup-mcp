        "name": "Frame Only",
        "eye": [80, -60, 50],
        "target": [24, 15, 15],
        "perspective": true,
        "visible_tags": "Frame"
      }
    },
    "operations_continued": [
      {
        "tool": "create_scene",
        "params": {
          "name": "Top Only",
          "eye": [80, -60, 50],
          "target": [24, 15, 15],
          "perspective": true,
          "visible_tags": "Top"
        }
      }
    ],
    "verify": [
      {
        "tool": "verify_scenes",
        "params": {},
        "note": "verify_scenes cycles through all scenes and reports visible layers for each — Frame Only should show only Frame tag, Top Only should show only Top tag, with no tag bleed between them"
      },
      {
        "tool": "eval_ruby",
        "params": {
          "code": "Sketchup.active_model.pages.count"
        },
        "expected_min": 2,
        "note": "At least 2 scenes exist"
      }
    ]
  },

  {
    "id": "scene-012",
    "category": "scene-creation",
    "description": "WW.cut_list via eval_ruby — verify board-feet calculation on a 3-part assembly",
    "setup": [
      {
        "tool": "eval_ruby",
        "params": {
          "code": "WW.reset!; WW.board('CL2 Top', [1.0, 24, 48], material: 'Walnut'); WW.board('CL2 Leg A', '2x2', 28, material: 'Walnut'); WW.board('CL2 Leg B', '2x2', 28, material: 'Walnut')"
        }
      }
    ],
    "operation": {
      "tool": "eval_ruby",
      "params": {
        "code": "WW.cut_list"
      }
    },
    "verify": [
      {
        "tool": "eval_ruby",
        "params": {
          "code": "cl = WW.cut_list; cl.is_a?(Array) && cl.length == 3"
        },
        "expected": true,
        "note": "Cut list returns exactly 3 entries (no part folding at WW level)"
      },
      {
        "tool": "eval_ruby",
        "params": {
          "code": "WW.board_feet > 0"
        },
        "expected": true,
        "note": "Board feet is a positive number"
      }
    ]
  },

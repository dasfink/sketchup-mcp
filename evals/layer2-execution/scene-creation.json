  {
    "id": "scene-005",
    "category": "scene-creation",
    "description": "Section plane through a dado joint — reveal the cross-section of a shelf-in-side joint",
    "setup": [
      {
        "tool": "create_component_box",
        "params": {
          "name": "SP Side",
          "position": [0, 0, 0],
          "dimensions": [0.75, 11.25, 30],
          "material": "Pine",
          "tag": "Carcase"
        }
      },
      {
        "tool": "create_component_box",
        "params": {
          "name": "SP Shelf",
          "position": [0.75, 0, 12],
          "dimensions": [22.5, 11.25, 0.75],
          "material": "Pine",
          "tag": "Carcase"
        }
      },
      {
        "tool": "safe_cut_dado",
        "params": {
          "component_name": "SP Side",
          "face": "y+",
          "z_start": 12,
          "z_end": 12.75,
          "depth": 0.375
        }
      }
    ],
    "operation": {
      "tool": "create_scene",
      "params": {
        "name": "Dado Section",
        "eye": [20, -40, 12.375],
        "target": [0.375, 5.625, 12.375],
        "perspective": false,
        "ortho_height": 6,
        "section_point": [5.0, 5.625, 0],
        "section_normal": [0, 1, 0]
      }
    },
    "verify": [
      {
        "tool": "verify_scenes",
        "params": {},
        "expected_contains": {
          "scene_name": "Dado Section",
          "camera_type": "orthographic"
        }
      },
      {
        "tool": "eval_ruby",
        "params": {
          "code": "Sketchup.active_model.entities.grep(Sketchup::SectionPlane).count"
        },
        "expected_min": 1,
        "note": "At least one section plane exists in the model"
      }
    ]
  },
  {
    "id": "scene-006",
    "category": "scene-creation",
    "description": "Exploded view — parts separated by tag with Z offsets",
    "setup": [
      {
        "tool": "create_component_box",
        "params": {
          "name": "EV Top",
          "position": [0, 0, 29],
          "dimensions": [48, 30, 1.0],
          "material": "Walnut",
          "tag": "Top"
        }
      },
      {
        "tool": "create_component_box",
        "params": {
          "name": "EV Leg 1",
          "position": [1, 1, 0],
          "dimensions": [1.5, 1.5, 29],
          "material": "Walnut",
          "tag": "Frame"
        }
      },
      {
        "tool": "create_component_box",
        "params": {
          "name": "EV Apron F",
          "position": [2.5, 0.25, 25],
          "dimensions": [43, 1.0, 3.5],
          "material": "Walnut",
          "tag": "Aprons"
        }
      }
    ],
    "operation": {
      "tool": "create_exploded_view",
      "params": {
        "offsets": "{\"Top\": 20, \"Aprons\": 10, \"Frame\": 0}",
        "tag_name": "Exploded"
      }
    },
    "verify": [
      {
        "tool": "eval_ruby",
        "params": {
          "code": "Sketchup.active_model.layers.any? { |l| l.name == 'Exploded' }"
        },
        "expected": true,
        "note": "Exploded tag was created"
      },
      {
        "tool": "eval_ruby",
        "params": {
          "code": "Sketchup.active_model.entities.select { |e| (e.is_a?(Sketchup::Group) || e.is_a?(Sketchup::ComponentInstance)) && e.layer.name == 'Exploded' }.count"
        },
        "expected_min": 1,
        "note": "At least one entity assigned to the Exploded tag"
      }
    ]
  },
  {
    "id": "scene-007",
    "category": "scene-creation",
    "description": "Cut list generation — 5-part assembly yields 5 entries in the cut list",
    "setup": [
      {
        "tool": "create_component_box",
        "params": {
          "name": "CL Top",
          "position": [0, 0, 29],
          "dimensions": [48, 30, 1.0],
          "material": "Walnut",
          "tag": "Top"
        }
      },
      {
        "tool": "create_component_box",
        "params": {
          "name": "CL Leg FL",
          "position": [1, 1, 0],
          "dimensions": [1.5, 1.5, 29],
          "material": "Walnut",
          "tag": "Frame"
        }
      },
      {
        "tool": "create_component_box",
        "params": {
          "name": "CL Leg FR",
          "position": [45.5, 1, 0],
          "dimensions": [1.5, 1.5, 29],
          "material": "Walnut",
          "tag": "Frame"
        }
      },
      {
        "tool": "create_component_box",
        "params": {
          "name": "CL Leg BL",
          "position": [1, 27.5, 0],
          "dimensions": [1.5, 1.5, 29],
          "material": "Walnut",
          "tag": "Frame"
        }
      },
      {
        "tool": "create_component_box",
        "params": {
          "name": "CL Leg BR",
          "position": [45.5, 27.5, 0],
          "dimensions": [1.5, 1.5, 29],
          "material": "Walnut",
          "tag": "Frame"
        }
      }
    ],
    "operation": {
      "tool": "generate_cutlist",
      "params": {
        "auto_orient": true,
        "part_folding": true
      }
    },
    "verify": [
      {
        "tool": "eval_ruby",
        "params": {
          "code": "Sketchup.active_model.entities.grep(Sketchup::Group).count + Sketchup.active_model.entities.grep(Sketchup::ComponentInstance).count"
        },
        "expected": 5,
        "note": "Model still has 5 components; cut list is read-only"
      }
    ]
  },
  {
    "id": "scene-008",
    "category": "scene-creation",
    "description": "Multi-scene plan — create all 4 standard views and verify total scene count",
    "setup": [
      {
        "tool": "create_component_box",
        "params": {
          "name": "MS Box",
          "position": [0, 0, 0],
          "dimensions": [36, 24, 30],
          "material": "Pine",
          "tag": "Carcase"
        }
      }
    ],
    "operation": {
      "tool": "eval_ruby",
      "params": {
        "code": "model = Sketchup.active_model; model.pages.to_a.each { |p| model.pages.erase(p) }; 'cleared'"
      }
    },
    "verify_pre": "Clears existing scenes before creating the batch",
    "operations": [
      {
        "tool": "create_scene",
        "params": {
          "name": "MS Overview",
          "eye": [80, -60, 50],
          "target": [18, 12, 15],
          "perspective": true
        }
      },
      {
        "tool": "create_scene",
        "params": {
          "name": "MS Front",
          "eye": [18, -100, 15],
          "target": [18, 0, 15],
          "perspective": false,
          "ortho_height": 40
        }
      },
      {
        "tool": "create_scene",
        "params": {
          "name": "MS Side",
          "eye": [136, 12, 15],
          "target": [36, 12, 15],
          "perspective": false,
          "ortho_height": 40
        }
      },
      {
        "tool": "create_scene",
        "params": {
          "name": "MS Plan",
          "eye": [18, 12, 200],
          "target": [18, 12, 0],
          "perspective": false,
          "up": [0, 1, 0],
          "ortho_height": 50
        }
      }
    ],
    "verify": [
      {
        "tool": "eval_ruby",
        "params": {
          "code": "Sketchup.active_model.pages.count"
        },
        "expected": 4,
        "note": "All 4 standard scenes were created"
      },
      {
        "tool": "verify_scenes",
        "params": {},
        "note": "Verify all scenes have correct camera types and no tag bleed"
      }
    ]
  },

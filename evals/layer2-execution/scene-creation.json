[
  {
    "id": "scene-001",
    "category": "scene-creation",
    "description": "Assembly overview — 3/4 perspective camera showing the whole model",
    "setup": [
      {
        "tool": "create_component_box",
        "params": {
          "name": "SC Table Top",
          "position": [0, 0, 29],
          "dimensions": [48, 30, 1.0],
          "material": "White Oak",
          "tag": "Top"
        }
      },
      {
        "tool": "create_component_box",
        "params": {
          "name": "SC Leg FL",
          "position": [1, 1, 0],
          "dimensions": [1.5, 1.5, 29],
          "material": "White Oak",
          "tag": "Frame"
        }
      },
      {
        "tool": "create_component_box",
        "params": {
          "name": "SC Leg FR",
          "position": [45.5, 1, 0],
          "dimensions": [1.5, 1.5, 29],
          "material": "White Oak",
          "tag": "Frame"
        }
      },
      {
        "tool": "create_component_box",
        "params": {
          "name": "SC Leg BL",
          "position": [1, 27.5, 0],
          "dimensions": [1.5, 1.5, 29],
          "material": "White Oak",
          "tag": "Frame"
        }
      },
      {
        "tool": "create_component_box",
        "params": {
          "name": "SC Leg BR",
          "position": [45.5, 27.5, 0],
          "dimensions": [1.5, 1.5, 29],
          "material": "White Oak",
          "tag": "Frame"
        }
      }
    ],
    "operation": {
      "tool": "create_scene",
      "params": {
        "name": "Assembly Overview",
        "eye": [80, -60, 50],
        "target": [24, 15, 15],
        "perspective": true
      }
    },
    "verify": [
      {
        "tool": "verify_scenes",
        "params": {},
        "expected_contains": {
          "scene_name": "Assembly Overview",
          "camera_type": "perspective"
        }
      }
    ]
  },
